{
  "Cosmos": {
    "Endpoint": "https://<your-cosmos-account>.documents.azure.com:443/",
    "Key": "<your-cosmos-key>",
    "Database": "IdpDatabase",
    "Container": "DocumentContainer"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
